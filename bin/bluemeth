#!/usr/bin/env bash
set -euo pipefail

DEFAULT_MINUTES=60
MAX_MINUTES=1440
TOKEN_FILE="/var/run/bluemeth/disablesleep.token"

help() {
  echo "bluemeth - timed macOS disablesleep"
  echo "usage: bluemeth [MIN=60] | off | status | -h"
  echo "max: ${MAX_MINUTES}m"
}

status() {
  local pmset_output
  pmset_output="$(/usr/bin/pmset -g 2>/dev/null || true)"

  printf '%s\n' "$pmset_output" | /usr/bin/awk '
    $1 == "SleepDisabled" { value = $2 }
    END {
      if (value == "") value = "unknown"
      print "SleepDisabled:", value
    }
  '

  [[ -f "$TOKEN_FILE" ]] && echo "token: present" || echo "token: none"
}

arg="${1:-$DEFAULT_MINUTES}"

if [[ $# -gt 1 ]]; then
  help
  exit 1
fi

case "$arg" in
  -h|--help|help)
    help
    exit 0
    ;;
  status)
    status
    exit 0
    ;;
  off)
    # shellcheck disable=SC2016
    /usr/bin/sudo /bin/sh -c '
      token_file="$1"
      /usr/bin/pmset -a disablesleep 0 && /bin/rm -f "$token_file"
    ' sh "$TOKEN_FILE"
    echo "off"
    exit 0
    ;;
esac

if [[ ! "$arg" =~ ^[0-9]+$ ]]; then
  help
  exit 1
fi

if (( arg <= 0 )); then
  echo "minutes must be > 0" >&2
  exit 1
fi

if (( arg > MAX_MINUTES )); then
  echo "minutes must be <= ${MAX_MINUTES}" >&2
  exit 1
fi

minutes="$arg"
seconds=$((minutes * 60))
token="$(/bin/date +%s)-$$-$(/usr/bin/uuidgen)"

# shellcheck disable=SC2016
/usr/bin/sudo /bin/sh -c '
  token_file="$1"
  token="$2"
  seconds="$3"
  token_dir="${token_file%/*}"

  /bin/mkdir -p "$token_dir"
  /bin/chmod 755 "$token_dir"

  umask 022
  printf "%s\n" "$token" > "$token_file"

  if ! /usr/bin/pmset -a disablesleep 1; then
    if [ -f "$token_file" ] && [ "$(/bin/cat "$token_file")" = "$token" ]; then
      /bin/rm -f "$token_file"
    fi
    exit 1
  fi

  (
    /bin/sleep "$seconds"

    if [ -f "$token_file" ] && [ "$(/bin/cat "$token_file")" = "$token" ]; then
      if /usr/bin/pmset -a disablesleep 0; then
        /bin/rm -f "$token_file"
      fi
    fi
  ) >/dev/null 2>&1 </dev/null &
' sh "$TOKEN_FILE" "$token" "$seconds"

echo "on: ${minutes}m"
