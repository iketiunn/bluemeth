#!/usr/bin/env bash
set -euo pipefail

DEFAULT_MINUTES=60
MAX_MINUTES=1440
TOKEN_FILE="/var/run/bluemeth/disablesleep.token"
LOCK_FILE="/var/run/bluemeth.lock"

help() {
  echo "bluemeth - timed macOS disablesleep"
  echo "usage: bluemeth [MIN=60] | off | status | -h"
  echo "max: ${MAX_MINUTES}m"
}

status() {
  local expires_at left now pmset_output sleep_state
  pmset_output="$(/usr/bin/pmset -g 2>/dev/null || true)"

  sleep_state="$(printf '%s\n' "$pmset_output" | /usr/bin/awk '
    $1 == "SleepDisabled" { value = $2 }
    END {
      if (value == "1") print "disabled"
      else if (value == "0") print "enabled"
      else print "unknown"
    }
  ')"

  echo "sleep: ${sleep_state}"

  if [[ ! -f "$TOKEN_FILE" ]]; then
    echo "timer: none"
    return 0
  fi

  read -r _token expires_at < "$TOKEN_FILE" || {
    echo "timer: unknown"
    return 0
  }

  if [[ ! "$expires_at" =~ ^[0-9]+$ ]]; then
    echo "timer: unknown"
    return 0
  fi

  now="$(/bin/date +%s)"
  left=$((expires_at - now))

  if (( left <= 0 )); then
    echo "timer: expired"
  elif (( left < 60 )); then
    echo "timer: <1m left"
  else
    echo "timer: $(((left + 59) / 60))m left"
  fi
}

arg="${1:-$DEFAULT_MINUTES}"

if [[ $# -gt 1 ]]; then
  help
  exit 1
fi

case "$arg" in
  -h|--help|help)
    help
    exit 0
    ;;
  status)
    status
    exit 0
    ;;
  off)
    # shellcheck disable=SC2016
    /usr/bin/sudo /usr/bin/lockf -k "$LOCK_FILE" /bin/sh -c '
      token_file="$1"
      if ! /usr/bin/pmset -a disablesleep 0; then
        exit 1
      fi

      /bin/rm -f "$token_file"

      root_domain="$(/usr/sbin/ioreg -r -n IOPMrootDomain -d 1 -l -w 0 2>/dev/null || true)"
      if printf "%s\n" "$root_domain" | /usr/bin/grep -Fq "\"AppleClamshellState\" = Yes"; then
        /usr/bin/pmset sleepnow
      fi
    ' sh "$TOKEN_FILE"
    echo "off"
    exit 0
    ;;
esac

if [[ ! "$arg" =~ ^[0-9]{1,4}$ ]]; then
  help
  exit 1
fi

minutes=$((10#$arg))

if (( minutes <= 0 )); then
  echo "minutes must be > 0" >&2
  exit 1
fi

if (( minutes > MAX_MINUTES )); then
  echo "minutes must be <= ${MAX_MINUTES}" >&2
  exit 1
fi

seconds=$((minutes * 60))
token="$(/bin/date +%s)-$$-$(/usr/bin/uuidgen)"
# shellcheck disable=SC2016
expire_script='
  token_file="$1"
  token="$2"

  current_token=""
  if [ -f "$token_file" ]; then
    read -r current_token _ < "$token_file" || current_token=""
  fi
  if [ "$current_token" = "$token" ]; then
    if /usr/bin/pmset -a disablesleep 0; then
      /bin/rm -f "$token_file"

      root_domain="$(/usr/sbin/ioreg -r -n IOPMrootDomain -d 1 -l -w 0 2>/dev/null || true)"
      if printf "%s\n" "$root_domain" | /usr/bin/grep -Fq "\"AppleClamshellState\" = Yes"; then
        /usr/bin/pmset sleepnow
      fi
    fi
  fi
'

# shellcheck disable=SC2016
/usr/bin/sudo /usr/bin/lockf -k "$LOCK_FILE" /bin/sh -c '
  set -e

  token_file="$1"
  token="$2"
  seconds="$3"
  lock_file="$4"
  expire_script="$5"
  token_dir="${token_file%/*}"
  now="$(/bin/date +%s)"
  expires_at=$((now + seconds))

  /bin/mkdir -p "$token_dir"
  /bin/chmod 755 "$token_dir"

  umask 022
  printf "%s %s\n" "$token" "$expires_at" > "$token_file"

  if ! /usr/bin/pmset -a disablesleep 1; then
    current_token=""
    if [ -f "$token_file" ]; then
      read -r current_token _ < "$token_file" || current_token=""
    fi
    if [ "$current_token" = "$token" ]; then
      /bin/rm -f "$token_file"
    fi
    exit 1
  fi

  (
    /bin/sleep "$seconds"
    /usr/bin/lockf -k "$lock_file" /bin/sh -c "$expire_script" sh "$token_file" "$token"
  ) >/dev/null 2>&1 </dev/null &
' sh "$TOKEN_FILE" "$token" "$seconds" "$LOCK_FILE" "$expire_script"

echo "on: ${minutes}m"
