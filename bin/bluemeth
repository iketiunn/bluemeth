#!/usr/bin/env bash
set -euo pipefail

DEFAULT_MINUTES=60
MAX_MINUTES=1440
TOKEN_FILE="/var/run/bluemeth/disablesleep.token"

help() {
  echo "bluemeth - timed macOS disablesleep"
  echo "usage: bluemeth [MIN=60] | off | status | -h"
  echo "max: ${MAX_MINUTES}m"
}

status() {
  local expires_at left now pmset_output sleep_state
  pmset_output="$(/usr/bin/pmset -g 2>/dev/null || true)"

  sleep_state="$(printf '%s\n' "$pmset_output" | /usr/bin/awk '
    $1 == "SleepDisabled" { value = $2 }
    END {
      if (value == "1") print "disabled"
      else if (value == "0") print "enabled"
      else print "unknown"
    }
  ')"

  echo "sleep: ${sleep_state}"

  if [[ ! -f "$TOKEN_FILE" ]]; then
    echo "timer: none"
    return 0
  fi

  read -r _token expires_at < "$TOKEN_FILE" || {
    echo "timer: unknown"
    return 0
  }

  if [[ ! "$expires_at" =~ ^[0-9]+$ ]]; then
    echo "timer: unknown"
    return 0
  fi

  now="$(/bin/date +%s)"
  left=$((expires_at - now))

  if (( left <= 0 )); then
    echo "timer: expired"
  elif (( left < 60 )); then
    echo "timer: <1m left"
  else
    echo "timer: $(((left + 59) / 60))m left"
  fi
}

arg="${1:-$DEFAULT_MINUTES}"

if [[ $# -gt 1 ]]; then
  help
  exit 1
fi

case "$arg" in
  -h|--help|help)
    help
    exit 0
    ;;
  status)
    status
    exit 0
    ;;
  off)
    # shellcheck disable=SC2016
    /usr/bin/sudo /bin/sh -c '
      token_file="$1"
      /usr/bin/pmset -a disablesleep 0 && /bin/rm -f "$token_file"
    ' sh "$TOKEN_FILE"
    echo "off"
    exit 0
    ;;
esac

if [[ ! "$arg" =~ ^[0-9]+$ ]]; then
  help
  exit 1
fi

if (( arg <= 0 )); then
  echo "minutes must be > 0" >&2
  exit 1
fi

if (( arg > MAX_MINUTES )); then
  echo "minutes must be <= ${MAX_MINUTES}" >&2
  exit 1
fi

minutes="$arg"
seconds=$((minutes * 60))
token="$(/bin/date +%s)-$$-$(/usr/bin/uuidgen)"

# shellcheck disable=SC2016
/usr/bin/sudo /bin/sh -c '
  set -e

  token_file="$1"
  token="$2"
  seconds="$3"
  token_dir="${token_file%/*}"
  now="$(/bin/date +%s)"
  expires_at=$((now + seconds))

  /bin/mkdir -p "$token_dir"
  /bin/chmod 755 "$token_dir"

  umask 022
  printf "%s %s\n" "$token" "$expires_at" > "$token_file"

  if ! /usr/bin/pmset -a disablesleep 1; then
    current_token=""
    if [ -f "$token_file" ]; then
      read -r current_token _ < "$token_file" || current_token=""
    fi
    if [ "$current_token" = "$token" ]; then
      /bin/rm -f "$token_file"
    fi
    exit 1
  fi

  (
    /bin/sleep "$seconds"

    current_token=""
    if [ -f "$token_file" ]; then
      read -r current_token _ < "$token_file" || current_token=""
    fi
    if [ "$current_token" = "$token" ]; then
      if /usr/bin/pmset -a disablesleep 0; then
        /bin/rm -f "$token_file"
      fi
    fi
  ) >/dev/null 2>&1 </dev/null &
' sh "$TOKEN_FILE" "$token" "$seconds"

echo "on: ${minutes}m"
